<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>YRU AI — Hybrid RAG Assistant</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0d1117;
      --bg2: #161b22;
      --bg3: #1c2128;
      --border: #30363d;
      --accent: #7c3aed;
      --accent2: #a855f7;
      --accent-glow: rgba(124,58,237,0.35);
      --text: #e6edf3;
      --text2: #8b949e;
      --user-bg: linear-gradient(135deg,#7c3aed,#a855f7);
      --ai-bg: #1c2128;
      --green: #3fb950;
      --red: #f85149;
    }

    body {
      font-family: 'Noto Sans Thai','Inter',sans-serif;
      background: var(--bg);
      color: var(--text);
      height: 100dvh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ── Header ── */
    header {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 24px;
      background: var(--bg2);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
      position: relative;
    }
    .logo {
      width: 38px; height: 38px;
      background: var(--user-bg);
      border-radius: 10px;
      display: grid; place-items: center;
      font-size: 18px;
      box-shadow: 0 0 16px var(--accent-glow);
    }
    .header-title h1 { font-size: 16px; font-weight: 600; letter-spacing: .3px; }
    .header-title p  { font-size: 12px; color: var(--text2); }
    .status-dot {
      margin-left: auto;
      display: flex; align-items: center; gap: 6px;
      font-size: 12px; color: var(--text2);
    }
    .dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--green);
      box-shadow: 0 0 6px var(--green);
      animation: pulse 2s infinite;
    }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

    /* ── Main Layout ── */
    main {
      flex: 1;
      display: flex;
      overflow: hidden;
    }

    /* ── Sidebar ── */
    aside {
      width: 260px;
      background: var(--bg2);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      overflow: hidden;
    }
    .sidebar-head {
      padding: 16px;
      border-bottom: 1px solid var(--border);
      font-size: 12px;
      color: var(--text2);
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 600;
    }
    .sidebar-body { flex: 1; overflow-y: auto; padding: 12px; }
    .sidebar-body::-webkit-scrollbar { width: 4px; }
    .sidebar-body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

    .quick-btn {
      width: 100%;
      padding: 10px 12px;
      margin-bottom: 6px;
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-family: inherit;
      font-size: 13px;
      text-align: left;
      cursor: pointer;
      transition: all .2s;
      line-height: 1.4;
    }
    .quick-btn:hover {
      background: var(--bg);
      border-color: var(--accent);
      color: var(--accent2);
    }
    .quick-btn .q-label {
      font-size: 10px;
      color: var(--text2);
      text-transform: uppercase;
      letter-spacing: .5px;
      margin-bottom: 3px;
    }

    .sidebar-stats {
      padding: 12px 16px;
      border-top: 1px solid var(--border);
      font-size: 12px;
      color: var(--text2);
    }
    .stat-row { display: flex; justify-content: space-between; margin-bottom: 4px; }
    .stat-val { color: var(--accent2); font-weight: 600; }

    /* ── Chat Area ── */
    .chat-area {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    #messages {
      flex: 1;
      overflow-y: auto;
      padding: 24px 20px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    #messages::-webkit-scrollbar { width: 4px; }
    #messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

    /* Welcome */
    .welcome {
      text-align: center;
      margin: auto;
      padding: 40px 20px;
    }
    .welcome .big-icon {
      font-size: 52px;
      margin-bottom: 16px;
      filter: drop-shadow(0 0 20px var(--accent-glow));
    }
    .welcome h2 { font-size: 22px; font-weight: 700; margin-bottom: 8px; }
    .welcome p  { font-size: 14px; color: var(--text2); max-width: 380px; margin: 0 auto; line-height: 1.7; }

    /* Message Bubbles */
    .msg { display: flex; gap: 10px; max-width: 820px; }
    .msg.user  { align-self: flex-end; flex-direction: row-reverse; }
    .msg.ai    { align-self: flex-start; }

    .avatar {
      width: 32px; height: 32px; border-radius: 50%;
      display: grid; place-items: center; font-size: 15px;
      flex-shrink: 0; margin-top: 2px;
    }
    .msg.user .avatar { background: var(--user-bg); box-shadow: 0 0 10px var(--accent-glow); }
    .msg.ai   .avatar { background: var(--bg3); border: 1px solid var(--border); }

    .bubble {
      padding: 12px 16px;
      border-radius: 14px;
      font-size: 14px;
      line-height: 1.7;
      max-width: 680px;
    }
    .msg.user .bubble {
      background: var(--user-bg);
      border-radius: 14px 4px 14px 14px;
      color: #fff;
      box-shadow: 0 4px 16px var(--accent-glow);
    }
    .msg.ai .bubble {
      background: var(--ai-bg);
      border: 1px solid var(--border);
      border-radius: 4px 14px 14px 14px;
    }

    .bubble table { border-collapse: collapse; width: 100%; margin-top: 8px; font-size: 13px; }
    .bubble table th, .bubble table td {
      border: 1px solid var(--border);
      padding: 6px 10px;
      text-align: left;
    }
    .bubble table th { background: var(--bg3); color: var(--accent2); }

    .msg-meta {
      font-size: 11px;
      color: var(--text2);
      margin-top: 5px;
      padding: 0 4px;
    }
    .source-tag {
      display: inline-flex; align-items: center; gap: 4px;
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2px 8px;
      font-size: 11px;
      color: var(--text2);
      margin: 4px 3px 0 0;
    }

    /* Typing indicator */
    .typing { display: flex; gap: 4px; padding: 6px 0; }
    .typing span {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--accent2); opacity: .4;
      animation: bounce .9s infinite;
    }
    .typing span:nth-child(2) { animation-delay: .15s; }
    .typing span:nth-child(3) { animation-delay: .30s; }
    @keyframes bounce { 0%,100%{transform:translateY(0);opacity:.4} 50%{transform:translateY(-5px);opacity:1} }

    /* ── Input Bar ── */
    .input-bar {
      padding: 16px 20px;
      background: var(--bg2);
      border-top: 1px solid var(--border);
      display: flex;
      gap: 10px;
      align-items: flex-end;
      flex-shrink: 0;
    }
    #query {
      flex: 1;
      padding: 12px 16px;
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 12px;
      color: var(--text);
      font-family: inherit;
      font-size: 14px;
      resize: none;
      min-height: 48px;
      max-height: 160px;
      overflow-y: auto;
      outline: none;
      transition: border-color .2s, box-shadow .2s;
      line-height: 1.5;
    }
    #query:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }
    #query::placeholder { color: var(--text2); }

    #send-btn {
      width: 48px; height: 48px;
      background: var(--user-bg);
      border: none; border-radius: 12px;
      color: #fff; font-size: 18px;
      cursor: pointer; flex-shrink: 0;
      display: grid; place-items: center;
      transition: opacity .2s, transform .1s, box-shadow .2s;
      box-shadow: 0 4px 14px var(--accent-glow);
    }
    #send-btn:hover { opacity:.85; transform: scale(1.05); }
    #send-btn:disabled { opacity:.4; cursor:not-allowed; transform:none; }

    /* mode selector */
    .mode-pills {
      display: flex; gap: 6px;
      padding: 0 20px 10px;
    }
    .pill {
      padding: 4px 12px;
      border-radius: 20px;
      border: 1px solid var(--border);
      background: var(--bg3);
      color: var(--text2);
      font-size: 12px;
      cursor: pointer;
      transition: all .2s;
      font-family: inherit;
    }
    .pill.active {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }

    @media (max-width: 640px) {
      aside { display: none; }
    }
  </style>
</head>
<body>

<!-- Header -->
<header>
  <div class="logo">🧠</div>
  <div class="header-title">
    <h1>YRU AI — Hybrid RAG</h1>
    <p>ถามตอบข้อมูลมหาวิทยาลัยด้วย bge-m3 + ChromaDB</p>
  </div>
  <div class="status-dot">
    <span class="dot" id="status-dot"></span>
    <span id="status-text">กำลังเชื่อมต่อ...</span>
  </div>
</header>

<main>
  <!-- Sidebar -->
  <aside>
    <div class="sidebar-head">คำถามด่วน</div>
    <div class="sidebar-body" id="quick-list">
      <!-- Filled by JS -->
    </div>
    <div class="sidebar-stats" id="db-stats">
      <div class="stat-row"><span>ChromaDB</span><span class="stat-val" id="stat-db">—</span></div>
      <div class="stat-row"><span>Collection</span><span class="stat-val" id="stat-col">documents</span></div>
      <div class="stat-row"><span>Backend</span><span class="stat-val" id="stat-be">—</span></div>
    </div>
  </aside>

  <!-- Chat -->
  <div class="chat-area">
    <div id="messages">
      <div class="welcome" id="welcome">
        <div class="big-icon">🤖</div>
        <h2>สวัสดีครับ! ผม YRU AI</h2>
        <p>ผมเชื่อมต่อกับฐานข้อมูลของมหาวิทยาลัยแล้ว พิมพ์คำถามได้เลยครับ หรือเลือกจากคำถามด่วนทางซ้าย</p>
      </div>
    </div>

    <!-- Mode selector -->
    <div class="mode-pills">
      <button class="pill active" data-mode="auto" onclick="setMode(this)">🤖 Auto</button>
      <button class="pill" data-mode="text" onclick="setMode(this)">📝 Text</button>
      <button class="pill" data-mode="table" onclick="setMode(this)">📊 Table</button>
      <button class="pill" data-mode="both" onclick="setMode(this)">🔀 Both</button>
    </div>

    <!-- Input -->
    <div class="input-bar">
      <textarea id="query" rows="1" placeholder="พิมพ์คำถามเกี่ยวกับข้อมูลมหาวิทยาลัย..."></textarea>
      <button id="send-btn" onclick="sendMessage()" title="ส่งคำถาม">➤</button>
    </div>
  </div>
</main>

<script src="js/app.js"></script>
<script>
  const API = window.location.origin;
  let currentMode = 'auto';
  let isLoading = false;

  const QUICK = [
    { label: 'แผนกลยุทธ์', q: 'ยุทธศาสตร์และแผนกลยุทธ์ของมหาวิทยาลัยมีอะไรบ้าง?' },
    { label: 'โครงการ', q: 'โครงการที่อยู่ในระบบมีอะไรบ้าง?' },
    { label: 'งบประมาณ', q: 'สรุปข้อมูลงบประมาณที่มีในระบบ' },
    { label: 'แผนงาน', q: 'แผนงานและโปรแกรมในระบบมีอะไรบ้าง?' },
    { label: 'KPI / ผลลัพธ์', q: 'ตัวชี้วัด KPI ที่ติดตามในระบบมีอะไรบ้าง?' },
    { label: 'ศูนย์/หน่วยงาน', q: 'ศูนย์หรือหน่วยงานที่มีในระบบ' },
    { label: 'การจอง', q: 'ข้อมูลการจองและการใช้งานทรัพยากร' },
  ];

  // Build sidebar quick questions
  const quickList = document.getElementById('quick-list');
  QUICK.forEach(({ label, q }) => {
    const btn = document.createElement('button');
    btn.className = 'quick-btn';
    btn.innerHTML = `<div class="q-label">${label}</div>${q}`;
    btn.onclick = () => { document.getElementById('query').value = q; sendMessage(); };
    quickList.appendChild(btn);
  });

  function setMode(el) {
    document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
    el.classList.add('active');
    currentMode = el.dataset.mode;
  }

  // Auto-resize textarea
  const queryEl = document.getElementById('query');
  queryEl.addEventListener('input', () => {
    queryEl.style.height = 'auto';
    queryEl.style.height = Math.min(queryEl.scrollHeight, 160) + 'px';
  });
  queryEl.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  });

  function addMsg(role, html, meta = null) {
    const welcome = document.getElementById('welcome');
    if (welcome) welcome.remove();

    const msgs = document.getElementById('messages');
    const wrap = document.createElement('div');
    wrap.className = `msg ${role}`;

    const av = role === 'user' ? '👤' : '🧠';
    wrap.innerHTML = `
      <div class="avatar">${av}</div>
      <div>
        <div class="bubble">${html}</div>
        ${meta ? `<div class="msg-meta">${meta}</div>` : ''}
      </div>`;
    msgs.appendChild(wrap);
    msgs.scrollTop = msgs.scrollHeight;
    return wrap;
  }

  function showTyping() {
    const msgs = document.getElementById('messages');
    const wrap = document.createElement('div');
    wrap.className = 'msg ai';
    wrap.id = 'typing-indicator';
    wrap.innerHTML = `<div class="avatar">🧠</div>
      <div class="bubble"><div class="typing"><span></span><span></span><span></span></div></div>`;
    msgs.appendChild(wrap);
    msgs.scrollTop = msgs.scrollHeight;
  }
  function removeTyping() {
    const el = document.getElementById('typing-indicator');
    if (el) el.remove();
  }

  async function sendMessage() {
    if (isLoading) return;
    const q = queryEl.value.trim();
    if (!q) return;

    isLoading = true;
    document.getElementById('send-btn').disabled = true;
    queryEl.value = '';
    queryEl.style.height = 'auto';

    addMsg('user', escapeHtml(q));
    showTyping();

    try {
      const res = await fetch(`${API}/ask`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: q, top_k: 5, mode: currentMode })
      });

      removeTyping();

      if (!res.ok) {
        const err = await res.text();
        addMsg('ai', `<span style="color:#f85149">❌ Error ${res.status}: ${escapeHtml(err)}</span>`);
        return;
      }

      const data = await res.json();
      const answerHtml = formatAnswer(data.answer);

      // Build source tags
      let sourceMeta = '';
      if (data.sources && data.sources.length) {
        const unique = [...new Set(data.sources.map(s => s.table || s.source || s.metadata?.table || 'ข้อมูล'))];
        sourceMeta = unique.slice(0, 5).map(s =>
          `<span class="source-tag">📂 ${escapeHtml(String(s))}</span>`
        ).join('');
      }
      const intentBadge = data.intent ? `<span class="source-tag">🎯 ${escapeHtml(data.intent)}</span>` : '';

      addMsg('ai', answerHtml, intentBadge + sourceMeta);
    } catch (err) {
      removeTyping();
      addMsg('ai', `<span style="color:#f85149">❌ เชื่อมต่อ Backend ไม่ได้: ${escapeHtml(err.message)}</span>`);
    } finally {
      isLoading = false;
      document.getElementById('send-btn').disabled = false;
      queryEl.focus();
    }
  }

  function formatAnswer(text) {
    if (!text) return '(ไม่มีคำตอบ)';
    // Markdown-lite
    return text
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
      .replace(/\*(.+?)\*/g,'<em>$1</em>')
      .replace(/\n/g,'<br>');
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;')
      .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // Health + DB stats check
  async function checkStatus() {
    try {
      const res = await fetch(`${API}/health`, { signal: AbortSignal.timeout(4000) });
      if (res.ok) {
        document.getElementById('status-dot').style.background = '#3fb950';
        document.getElementById('status-dot').style.boxShadow = '0 0 6px #3fb950';
        document.getElementById('status-text').textContent = 'เชื่อมต่อแล้ว';
        document.getElementById('stat-be').textContent = '✅ Online';
      }
    } catch {
      document.getElementById('status-dot').style.background = '#f85149';
      document.getElementById('status-dot').style.boxShadow = '0 0 6px #f85149';
      document.getElementById('status-text').textContent = 'ไม่สามารถเชื่อมต่อได้';
      document.getElementById('stat-be').textContent = '❌ Offline';
    }
    try {
      const r2 = await fetch(`${API}/api/database/stats`, { signal: AbortSignal.timeout(5000) });
      if (r2.ok) {
        const d = await r2.json();
        if (d.status === 'success') {
          document.getElementById('stat-db').textContent = '✅ Online';
        }
      }
    } catch { document.getElementById('stat-db').textContent = '?'; }
  }

  checkStatus();
  setInterval(checkStatus, 30000);
</script>
</body>
</html>
